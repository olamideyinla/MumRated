# ── App ───────────────────────────────────────────────────────────────────
# The public URL of this deployment (used for metadata & OpenGraph)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL via Prisma) ─────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/mumrated

# Direct connection for Prisma Migrate (bypasses pooler)
DIRECT_URL=postgresql://postgres:password@localhost:5432/mumrated

# ── Auth.js (v5) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# REQUIRED — canonical URL of this deployment.
# Auth.js embeds this in magic-link emails. If it doesn't match the domain
# the user is browsing, the session cookie lands on the wrong origin and
# sign-in silently fails (user is looped back to /sign-in).
#   • Local dev  → AUTH_URL=http://localhost:3000
#   • Production → AUTH_URL=https://mumrated.com   (set in Vercel dashboard)
AUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (transactional email / magic-link) — https://resend.com
AUTH_RESEND_KEY=
EMAIL_FROM=noreply@mumrated.com

# ── Cloudinary (image uploads) ────────────────────────────────────────────
# From your Cloudinary dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public key used client-side for unsigned uploads (optional)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── Vercel / Cloudflare ───────────────────────────────────────────────────
# Set automatically by Vercel — no manual action needed:
#   VERCEL_URL
#   VERCEL_ENV (development | preview | production)

# Cloudflare Turnstile (bot protection on review form) — optional for MVP
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ── reCAPTCHA v3 ──────────────────────────────────────────────────────────
# Create at https://www.google.com/recaptcha/admin — choose v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── OpenAI (medical claims moderation) ────────────────────────────────────
# Get at https://platform.openai.com/api-keys
# If unset, medical claims check is skipped (dev only — always set in prod)
OPENAI_API_KEY=

# ── Admin access ──────────────────────────────────────────────────────────
# Comma-separated list of email addresses that can access /admin/*
ADMIN_EMAILS="admin@example.com,ops@example.com"

# ── Sentry (error tracking) ───────────────────────────────────────────────
# Create a project at https://sentry.io — choose Next.js
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser (safe — DSNs are public)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=mumrated
SENTRY_PROJECT=mumrated-web
# Generate a Sentry auth token at: Settings → Auth Tokens → Create New Token
# Scope required: project:releases, org:read
# This token is used ONLY at build time to upload source maps — never shipped to users.
SENTRY_AUTH_TOKEN=

# ── Uptime monitoring ─────────────────────────────────────────────────────
# Better Stack (recommended) or UptimeRobot — no env vars needed here.
# Add monitors manually in the Better Stack / UptimeRobot dashboard.
# Targets: https://mumrated.com/ and https://mumrated.com/listing/[real-slug]

# ── Feature flags (optional) ──────────────────────────────────────────────
# Set to "true" to enable
NEXT_PUBLIC_ENABLE_PROVIDER_CLAIMS=false
NEXT_PUBLIC_ENABLE_WAITLIST=true
