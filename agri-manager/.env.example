# Copy this file to .env.development and fill in your values
# Never commit real credentials to git

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Environment identifier (development | staging | production)
VITE_ENV=development

# App version (matches package.json version)
VITE_APP_VERSION=0.1.0

# Sentry — get from https://sentry.io (optional, leave blank to disable)
VITE_SENTRY_DSN=

# Plausible Analytics — your site domain (optional, leave blank to disable)
VITE_PLAUSIBLE_DOMAIN=
